# Base URL of the Organikaly backend REST API (CONTRACT §10 / STORE_CONTRACT §15.1)
VITE_API_BASE=http://localhost:8000/api/v1

# Optional UI feature flag for the Store workspace (STORE_CONTRACT §15.1).
# Defaults to true; set to "false" to hide the Store workspace switcher/nav.
VITE_STORE_ENABLED=true

# ---------------------------------------------------------------------------
# Map basemap (OUTLET_MAP_CONTRACT §2)
# ---------------------------------------------------------------------------
# Raster {z}/{x}/{y} tile URL for the Outlets / Live Ops map.
# Default (leave blank to use it): CARTO Positron — OpenStreetMap data in a light,
# muted style that sits under the brand palette without fighting the status pins.
# Override to point at a self-hosted OSM render or a paid provider.
# VITE_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png

# Attribution shown on the map. Only set this if you override VITE_MAP_TILE_URL —
# the tile provider must be credited. Attribution is a LICENCE CONDITION of the
# OpenStreetMap data (ODbL), not a design choice: the OpenStreetMap credit is
# appended automatically if this string omits it, and there is no way to turn it
# off. Do not try.
# VITE_MAP_TILE_ATTRIBUTION=&copy; <a href="https://carto.com/attributions">CARTO</a>
